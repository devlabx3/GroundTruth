# Supabase (Auth, Storage, Realtime) — SOLO estos usos, nunca consultas de negocio directas
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Backend NestJS (toda la lógica de negocio via Axios)
VITE_API_BASE_URL=http://localhost:3000
# Solana
VITE_SOLANA_CLUSTER=devnet
VITE_SOLANA_RPC_URL=

# ─── Accesos rápidos por rol en el login (OPCIONAL, solo depuración) ───────────
# Pintan un botón por rol debajo del formulario que entra por el flujo REAL
# (Supabase Auth → /me → rol derivado). Sirven para depurar privilegios sin
# teclear credenciales.
#
# Seguridad: `lib/devLogins.ts` los descarta con `import.meta.env.DEV`, así que en
# un build de producción la rama entera se elimina y las contraseñas NO llegan al
# bundle (verificado). Si no defines estas variables, los botones no aparecen.
VITE_DEV_OPERADOR_EMAIL=
VITE_DEV_OPERADOR_PASSWORD=
VITE_DEV_LOGISTICA_EMAIL=
VITE_DEV_LOGISTICA_PASSWORD=
VITE_DEV_AGRICULTOR_EMAIL=
VITE_DEV_AGRICULTOR_PASSWORD=
VITE_DEV_ADMIN_EMAIL=
VITE_DEV_ADMIN_PASSWORD=
