# Puerto del API (el frontend espera http://localhost:3000)
PORT=3000

# Orígenes permitidos para CORS (frontend dev)
CORS_ORIGIN=http://localhost:5173

# URL del proyecto Supabase — para validar JWT (JWKS) y construir el issuer.
SUPABASE_URL=https://<ref>.supabase.co

# Conexión a Postgres (rol de servicio — OMITE RLS; este backend autoriza por privilegios).
# IMPORTANTE: usar el POOLER, no la conexión directa `db.<ref>.supabase.co:5432`
# (esa resuelve solo a IPv6 y falla con ENETUNREACH en redes sin IPv6).
# Dashboard → Settings → Database → Connection string → "Transaction pooler".
# El usuario es `postgres.<ref>` y el host es aws-N-<region>.pooler.supabase.com:6543.
# El pool activa TLS automáticamente para hosts remotos (ver db.service.ts).
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres


# ─────────────────────────────────────────────────────────────────────────────
# Todo lo de abajo es OPCIONAL. Si una pieza no está configurada, se apaga sola y
# el resto sigue funcionando: no se inventa un dato ni se finge una integración.
# ─────────────────────────────────────────────────────────────────────────────

# --- Capa on-chain (Solana) ---
# Sin ESTAS CINCO, la certificación cae a su ruta pre-Solana: una transacción en la
# BD que imita los efectos on-chain (útil para demos sin cadena).
# Para levantarlas en local: `node scripts/bootstrap-solana.mjs <operador_id>`
# (crea el USDC de prueba, la Config, el árbol de certificados y la tesorería).
SOLANA_RPC_URL=http://127.0.0.1:8899
# Keypair custodial del backend: array JSON de 64 bytes.
# ⚠ RIESGO F5: en producción va a KMS/HSM, NUNCA en un fichero en disco.
SOLANA_BACKEND_SECRET_KEY=[...]
SOLANA_USDC_MINT=
SOLANA_MERKLE_TREE=
SOLANA_PLATAFORMA_ATA=

# --- Evidencia: Storage (PDF del certificado e imagen satelital) ---
# Sin esta clave no hay PDF ni imagen en Storage, y sus hashes van en ceros.
SUPABASE_SERVICE_ROLE_KEY=

# --- Evidencia: imagen satelital (Sentinel Hub / Copernicus) ---
# Sin credenciales no hay imagen satelital ni su hash. El pipeline está cableado:
# en cuanto existan, se enciende sin tocar código.
SENTINEL_CLIENT_ID=
SENTINEL_CLIENT_SECRET=
# SENTINEL_BASE_URL=https://services.sentinel-hub.com

# --- Evidencia: Arweave (GeoJSON permanente, vía Irys) ---
# `devnet` (por defecto) es EFÍMERO: los datos caducan a los ~60 días.
# ⚠ `mainnet` publica la GEOLOCALIZACIÓN DE LAS FINCAS de forma permanente e
#   irreversible. Es una decisión explícita, no un descuido de configuración.
IRYS_NETWORK=devnet

# --- Depósitos a tesorería (webhook de Helius) ---
# El webhook es PÚBLICO (lo llama Helius, no una persona): se autentica con este
# secreto compartido, comparado en tiempo constante. Sin él, el endpoint queda
# CERRADO — un endpoint público sin autenticar es peor que no tenerlo.
HELIUS_WEBHOOK_SECRET=
HELIUS_API_KEY=
